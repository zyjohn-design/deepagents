# Orchestrator model (frontier - configurable via init_chat_model format)
ORCHESTRATOR_MODEL=anthropic:claude-sonnet-4-6
# Alternatives:
# ORCHESTRATOR_MODEL=openai:gpt-4.1
# ORCHESTRATOR_MODEL=google_genai:gemini-3-pro

# NVIDIA API Key (for Nemotron Super subagents via NIM)
NVIDIA_API_KEY=nvapi-...

# Anthropic API Key (if using Claude as orchestrator)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (if using GPT as orchestrator)
# OPENAI_API_KEY=sk-...

# Tavily API Key (web search)
TAVILY_API_KEY=tvly-...

# LangSmith (tracing)
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT="blueprint-gpu-skills"
LANGSMITH_TRACING="true"


# Modal (GPU sandbox for code execution)
MODAL_TOKEN_ID=
MODEL_TOKEN_SECRET=

# Background job isolated loops for LangSmith Deployments
BG_JOB_ISOLATED_LOOPS=true